{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "基础权限配置",
  "windows": [ "main" ],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:allow-open",
    "fs:allow-read",
    "fs:allow-read-text-file",
    "fs:read-files",
    "fs:read-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "C:/**" },
        { "path": "D:/**" },
        { "path": "E:/**" }
      ]
    }
  ]
}